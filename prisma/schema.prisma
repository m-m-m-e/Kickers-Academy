generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== HOME MODULE =====================

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AboutSection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===================== PROGRAMS MODULE =====================

model ProgramGroup {
  id          String               @id @default(cuid())
  slug        String               @unique
  ageGroup    String
  title       String
  description String
  image       String
  featured    Boolean              @default(false)
  subSections ProgramSubSection[]
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model ProgramSubSection {
  id             String        @id @default(cuid())
  programGroupId String
  programGroup   ProgramGroup  @relation(fields: [programGroupId], references: [id], onDelete: Cascade)
  title          String
  description    String
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([programGroupId])
}

// ===================== NEWS & EVENTS MODULE =====================

model NewsEvent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String?
  image       String
  kind        String   @default("news")
  featured    Boolean  @default(false)
  publishedAt DateTime
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===================== GALLERY MODULE =====================

model GalleryCategory {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String
  image       String
  featured    Boolean         @default(false)
  items       GalleryMedia[]
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model GalleryMedia {
  id         String          @id @default(cuid())
  categoryId String
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String
  description String
  mediaType  String          @default("image")
  src        String
  thumbnail  String
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([categoryId])
}

// ===================== STORE MODULE =====================

model StoreCategory {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String
  image       String
  featured    Boolean        @default(false)
  products    StoreProduct[]
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model StoreProduct {
  id                  String        @id @default(cuid())
  categoryId          String
  category            StoreCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title               String
  description         String
  image               String
  price               String
  featured            Boolean       @default(false)
  colorOptions        String        @default("")
  sizeOptions         String        @default("")
  supportsNumber      Boolean       @default(false)
  supportsName        Boolean       @default(false)
  supportsCustomMade  Boolean       @default(false)
  order               Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([categoryId])
}

// ===================== FOOTER MODULE =====================

model FooterContent {
  id          String   @id @default(cuid())
  brandName   String
  badgeLabel  String
  description String
  location    String
  email       String
  whatsapp    String
  phone       String
  updatedAt   DateTime @updatedAt
}

model FooterLink {
  id    String @id @default(cuid())
  label String
  href  String
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FooterSocial {
  id    String @id @default(cuid())
  label String
  href  String
  icon  String
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FooterBrand {
  id    String @id @default(cuid())
  label String
  href  String
  kind  String @default("sponsor")
  badgeImage String @default("")
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== SHARED CONTENT =====================

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  payload   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== JOIN MODULE =====================

model JoinRegistration {
  id                      String    @id @default(cuid())
  playerName              String
  dateOfBirth             String
  guardianName            String
  guardianEmail           String
  guardianPhone           String
  emergencyContact        String
  address                 String    @default("")
  residence               String    @default("")
  medicalInformation      String    @default("")
  consent                 Boolean   @default(false)
  photoPublicationConsent String    @default("denied")
  status                  String    @default("pending")
  submittedAt             DateTime  @default(now())
  reviewedAt              DateTime?
  adminNote               String    @default("")
  whatsappConfirmedAt     DateTime?
  emailConfirmedAt        DateTime?

  @@index([status])
  @@index([submittedAt])
}

// ===================== CONTACT MODULE =====================

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String   @default("")
  subject     String
  message     String
  status      String   @default("new")
  submittedAt DateTime @default(now())
  adminNote   String   @default("")

  @@index([status])
  @@index([submittedAt])
}

model FeedbackSubmission {
  id          String    @id @default(cuid())
  name        String
  message     String
  rating      Int       @default(5)
  status      String    @default("pending")
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  adminNote   String    @default("")

  @@index([status])
  @@index([submittedAt])
}

// ===================== ENGAGE MODULE =====================

model EngageSubmission {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String   @default("")
  engagementType String
  occupation     String   @default("")
  skills         String   @default("")
  message        String
  status         String   @default("new")
  submittedAt    DateTime @default(now())
  adminNote      String   @default("")

  @@index([status])
  @@index([submittedAt])
}

model EngageConnectionRequest {
  id                   String   @id @default(cuid())
  targetSubmissionId   String   @default("")
  targetOccupation     String   @default("")
  targetEngagementType String   @default("")
  requesterName        String
  requesterEmail       String
  requesterPhone       String   @default("")
  reason               String
  status               String   @default("new")
  submittedAt          DateTime @default(now())
  adminNote            String   @default("")

  @@index([status])
  @@index([submittedAt])
}

model SupportSubmission {
  id                     String   @id @default(cuid())
  name                   String
  email                  String
  phone                  String   @default("")
  supportType            String
  supportDetails         String   @default("")
  preferredPaymentStream String   @default("")
  amount                 String   @default("")
  status                 String   @default("new")
  submittedAt            DateTime @default(now())
  adminNote              String   @default("")

  @@index([status])
  @@index([submittedAt])
}

// ===================== STORE ORDERS MODULE =====================

model StoreOrder {
  id                 String          @id @default(cuid())
  buyerName          String
  buyerEmail         String
  buyerPhone         String          @default("")
  deliveryPreference String          @default("")
  notes              String          @default("")
  items              StoreOrderItem[]
  status             String          @default("new")
  submittedAt        DateTime        @default(now())
  adminNote          String          @default("")

  @@index([status])
  @@index([submittedAt])
}

model StoreOrderItem {
  id                 String     @id @default(cuid())
  orderId            String
  order              StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId          String
  productTitle       String
  productImage       String     @default("")
  basePrice          String     @default("")
  customizationPrice String     @default("")
  unitPrice          String     @default("")
  lineTotal          String     @default("")
  color              String     @default("")
  size               String     @default("")
  quantity           Int        @default(1)
  name               String     @default("")
  number             String     @default("")
  customMade         Boolean    @default(false)

  @@index([orderId])
}
